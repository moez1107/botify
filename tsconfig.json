{
  "$schema": "https://json.schemastore.org/tsconfig",
  "compilerOptions": {
    // Language and environment
    "target": "ES2022",
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "jsx": "preserve",
    // Modules
    "module": "ESNext",
    "moduleResolution": "bundler",
    // Type checking & strictness
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "forceConsistentCasingInFileNames": true,
    "noFallthroughCasesInSwitch": true,
    "noImplicitOverride": true,
    "noPropertyAccessFromIndexSignature": true,
    // Interop & bundler
    "allowJs": true,
    "esModuleInterop": true,
    "isolatedModules": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    // Next.js specific
    "plugins": [
      {
        "name": "next"
      }
    ],
    "incremental": true,
    "noEmit": true,
    // Paths (aliases)
    "baseUrl": ".",
    "paths": {
      "@/*": [
        "./*"
      ],
      "@/components/*": [
        "components/*"
      ],
      "@/lib/*": [
        "lib/*"
      ],
      "@/app/*": [
        "app/*"
      ],
      "swr": [
        "./lib/swr"
      ]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    ".next",
    "out",
    "dist",
    "tests",
    "dist-tests",
    "mobile",
    "jobs",
    "**/*.spec.ts",
    "**/*.test.ts"
  ]
}
